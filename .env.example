# Neon DB (PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# AES-256 Encryption Key — generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_32_byte_hex_key_here

# System Gmail account for sending OTP emails
SYSTEM_GMAIL=your.sender@gmail.com
SYSTEM_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Cron job protection secret — generate with: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here

# Public base URL (used for Vercel Cron)
NEXTAUTH_URL=https://your-app.vercel.app
